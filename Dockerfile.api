FROM python:3.12-slim

WORKDIR /app

COPY pyproject.toml .
RUN pip install --no-cache-dir .[web]

COPY engine/ engine/
COPY agents/ agents/
COPY llm/ llm/
COPY data/ data/
COPY api/ api/
COPY cli/ cli/

ENV PYTHONPATH=/app

EXPOSE 8000

CMD ["uvicorn", "api.server:app", "--host", "0.0.0.0", "--port", "8000"]
